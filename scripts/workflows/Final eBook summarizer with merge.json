      "name": "Merge NE"
    },
    {
      "parameters": {
        "jsCode": "\nconst fs = require('fs');\nconst { execSync } = require('child_process');\n\n/* V9: Force new binary key 'merged_audio' */\n\nconst debugFile = '/tmp/n8n_debug_en_v9.txt';\nconst log = (msg) => {\n    try { fs.appendFileSync(debugFile, msg + '\\n'); } catch(e) {}\n    console.log(msg);\n};\n\ntry { fs.unlinkSync(debugFile); } catch(e) {}\nlog(\"--- V9 START (en) ---\");\n\nfor (let i = 0; i < items.length; i++) {\n    const item = items[i];\n    \n    // Find Header\n    let binaryKey = 'data';\n    if (item.binary && !item.binary[binaryKey]) {\n        binaryKey = Object.keys(item.binary)[0];\n    }\n    \n    if (!item.binary || !binaryKey) {\n        log(`Item ${i}: No binary found.`);\n        continue;\n    }\n    \n    // 1. GET DATA BUFFER SAFELY\n    let buffer;\n    try {\n        buffer = await this.helpers.getBinaryDataBuffer(i, binaryKey);\n        log(`Buffer loaded. Size: ${buffer.length} bytes`);\n    } catch (err) {\n        log(`Failed: ${err.message}`);\n        continue;\n    }\n\n    // 2. Write Temp Input\n    const uniqueId = Math.random().toString(36).substring(7);\n    const tempInput = `/tmp/input_${uniqueId}.mp3`;\n    const tempOutput = `/tmp/output_${uniqueId}.mp3`;\n    const introPath = '/home/node/.n8n/intro_en.mp3';\n    const outroPath = '/home/node/.n8n/outro_en.mp3';\n    \n    try {\n         fs.writeFileSync(tempInput, buffer);\n         \n         const hasIntro = fs.existsSync(introPath);\n         const hasOutro = fs.existsSync(outroPath);\n         \n         let cmd = 'ffmpeg -y ';\n         let filter = [];\n         let inputs = [];\n         let idx = 0;\n    \n         if (hasIntro) {\n            inputs.push(`-i \"${introPath}\"`);\n            filter.push(`[${idx}:a]`);\n            idx++;\n         }\n    \n         inputs.push(`-i \"${tempInput}\"`);\n         filter.push(`[${idx}:a]`);\n         idx++;\n    \n         if (hasOutro) {\n            inputs.push(`-i \"${outroPath}\"`);\n            filter.push(`[${idx}:a]`);\n            idx++;\n         }\n         \n         // Even if no intro/outro, we act as a \"pass-through\" but explicit write to guarantee key exists\n         // But optimization: if no intro/outro, just copy buffer to new key?\n         // Let's run ffmpeg always to be safe on format regularizing.\n         \n         const filterStr = filter.join('') + `concat=n=${idx}:v=0:a=1[out]`;\n         cmd += inputs.join(' ') + ` -filter_complex \"${filterStr}\" -map \"[out]\" \"${tempOutput}\"`;\n         \n         execSync(cmd + ' 2>&1', { encoding: 'utf8' });\n         \n         if (fs.existsSync(tempOutput)) {\n             const newBuf = fs.readFileSync(tempOutput);\n             log(`Merged created. New size: ${newBuf.length}`);\n             \n             // Update Item - CRITICAL: USE NEW KEY\n             item.binary['merged_audio'] = await this.helpers.prepareBinaryData(newBuf, `merged_en.mp3`, 'audio/mp3');\n             \n             fs.unlinkSync(tempOutput);\n         }\n         fs.unlinkSync(tempInput);\n         \n    } catch (err) {\n        log(\"Error: \" + err.message);\n    }\n}\n\nreturn items;\n"
      },
