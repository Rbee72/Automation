filter.push(`[${idx}:a]`);\n            idx++;\n         }\n         \n         // Even if no intro/outro, we act as a \"pass-through\" but explicit write to guarantee key exists\n         // But optimization: if no intro/outro, just copy buffer to new key?\n         // Let's run ffmpeg always to be safe on format regularizing.\n         \n         const filterStr = filter.join('') + `concat=n=${idx}:v=0:a=1[out]`;\n         cmd += inputs.join(' ') + ` -filter_complex \"${filterStr}\" -map \"[out]\" \"${tempOutput}\"`;\n         \n         execSync(cmd + ' 2>&1', { encoding: 'utf8' });\n         \n         if (fs.existsSync(tempOutput)) {\n             const newBuf = fs.readFileSync(tempOutput);\n             log(`Merged created. New size: ${newBuf.length}`);\n             \n             // Update Item - CRITICAL: USE NEW KEY\n             item.binary['merged_audio'] = await this.helpers.prepareBinaryData(newBuf, `merged_ne.mp3`, 'audio/mp3');\n             \n             fs.unlinkSync(tempOutput);\n         }\n         fs.unlinkSync(tempInput);\n         \n    } catch (err) {\n        log(\"Error: \" + err.message);\n    }\n}\n\nreturn items;\n"
